# Copy this file to .env and fill in your own values.
# Never commit .env — it's already gitignored.

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/manus-ai-clone

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:8000

# --- Auth (NextAuth + Google OAuth) ---
NEXTAUTH_URL=http://localhost:8000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM providers (at least one required) ---
CEREBRAS_API_KEY=
FIRE_WORKS_API_KEY=
COHERE_API_KEY=

# --- Vector store (long-term memory) ---
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Web search (deep agent web browsing) ---
EXA_SEARCH_API_KEY=

# --- Code sandbox (OpenSandbox, runs locally via Docker — see docker-compose.yml) ---
# No API key needed for local use. OPENSANDBOX_URL is preferred; OPENSANDBOX_DOMAIN /
# OPENSANDBOX_PROTOCOL are supported as a fallback if OPENSANDBOX_URL is unset.
OPENSANDBOX_URL=http://localhost:8080
